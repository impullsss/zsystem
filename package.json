{
  "name": "zsystem",
  "version": "0.8.5",
  "description": "ZSystem — Foundry VTT system",
  "main": "dist/zsystem.js",
  "scripts": {
    "clean": "rimraf dist",
    "build": "rollup -c",
    "watch": "rollup -c -w",
    "test": "node --test --experimental-default-type=module tests",
    "sim:balance": "node --experimental-default-type=module scripts/simulate-balance.mjs",
    "sim:firearms": "node --experimental-default-type=module scripts/simulate-firearms.mjs",
    "sim:trauma": "node --experimental-default-type=module scripts/simulate-trauma.mjs",
    "sim:ammo": "node --experimental-default-type=module scripts/simulate-ammo.mjs",
    "sim:protection": "node --experimental-default-type=module scripts/simulate-protection.mjs",
    "sim:travel": "node --experimental-default-type=module scripts/simulate-travel.mjs",
    "sim:economy": "node --experimental-default-type=module scripts/simulate-survival-economy.mjs"
  },
  "author": "impullsss",
  "license": "MIT",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.0.1",
    "@rollup/plugin-commonjs": "^24.0.0",
    "rollup": "^3.29.0",
    "rimraf": "^5.0.0"
  }
}
