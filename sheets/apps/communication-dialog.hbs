<form class="z-communication-form">
  <div class="form-group">
    <label>С кем общаемся</label>
    <select name="targetUuid">
      <option value="">Без цели</option>
      {{#each targetOptions as |target|}}
      <option value="{{target.uuid}}" {{#if (eq ../targetUuid target.uuid)}}selected{{/if}}>{{target.name}}</option>
      {{/each}}
    </select>
  </div>

  {{#if targetActor}}
  <div style="border:1px solid #444; border-radius:6px; padding:10px; margin-bottom:10px; background:rgba(0,0,0,0.08);">
    <div style="display:flex; justify-content:space-between; align-items:center; gap:8px;">
      <div>
        <div style="font-weight:bold;">{{targetActor.name}}</div>
        <div style="font-size:0.85em; color:#999;">{{targetActor.type}}</div>
      </div>
      <div style="font-size:1.4em; color:{{attitudeMeta.color}};">{{attitudeMeta.icon}}</div>
    </div>

    <div style="margin-top:8px; font-size:0.9em;">
      <div><strong>Отношение:</strong> <span style="color:{{attitudeMeta.color}};">{{attitudeMeta.label}}</span></div>
      <div><strong>Пресет:</strong> {{presetLabel}}</div>
      {{#if (and isGM social.notes)}}
      <div style="margin-top:6px; color:#555;"><strong>Заметка:</strong> {{social.notes}}</div>
      {{/if}}
    </div>

    {{#if (and isGM (or (eq targetActor.type "npc") (eq targetActor.type "survivor")))}}
    <div style="display:flex; gap:6px; margin-top:10px; flex-wrap:wrap;">
      {{#each attitudeOptions as |option|}}
      <button type="button" class="comm-set-attitude" data-attitude="{{option.key}}">{{option.label}}</button>
      {{/each}}
    </div>
    {{/if}}
  </div>
  {{/if}}

  <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px;">
    <button type="button" class="comm-open-check" data-skill="diplomacy"><i class="fas fa-comments"></i> Дипломатия</button>
    <button type="button" class="comm-open-check" data-skill="leadership"><i class="fas fa-bullhorn"></i> Лидерство</button>
  </div>

  <div style="margin-top:8px; display:flex; justify-content:flex-end;">
    <button type="button" class="comm-open-sheet"><i class="fas fa-user"></i> Открыть лист</button>
  </div>
</form>
