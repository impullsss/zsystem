<form class="{{cssClass}} z-vehicle-sheet" autocomplete="off">
    <header class="z-vehicle-header">
        <img class="profile-img" src="{{actor.img}}" data-edit="img" height="86" width="86"/>
        <div class="z-vehicle-heading">
            <input name="name" type="text" value="{{actor.name}}" placeholder="Название транспорта"/>
            <div class="z-vehicle-vitals">
                <label>
                    <span>Топливо</span>
                    <b><input type="number" name="system.resources.fuel.value" value="{{system.resources.fuel.value}}"/> / <input type="number" name="system.resources.fuel.max" value="{{system.resources.fuel.max}}"/></b>
                </label>
                <label>
                    <span>Прочность</span>
                    <b><input type="number" name="system.resources.hp.value" value="{{system.resources.hp.value}}"/> / <input type="number" name="system.resources.hp.max" value="{{system.resources.hp.max}}"/></b>
                </label>
                <label class="z-vehicle-broken-toggle">
                    <span>Неисправен</span>
                    <input type="hidden" name="system.broken" value="false"/>
                    <input type="checkbox" name="system.broken" value="true" {{checked system.broken}}/>
                </label>
            </div>
        </div>
    </header>

    <nav class="sheet-tabs tabs z-vehicle-tabs" data-group="primary">
        <a class="item" data-tab="stats">Характеристики</a>
        <a class="item" data-tab="cargo">Багажник</a>
        <a class="item" data-tab="passengers">Пассажиры</a>
    </nav>

    <section class="sheet-body z-vehicle-body">
        <div class="tab stats" data-group="primary" data-tab="stats">
            <div class="z-vehicle-grid">
                <section class="z-vehicle-panel">
                    <h3>Параметры движения</h3>
                    <div class="form-group">
                        <label>Скорость, км/ч</label>
                        <input type="number" name="system.attributes.speed.value" value="{{system.attributes.speed.value}}"/>
                    </div>
                    <div class="form-group">
                        <label>Управляемость</label>
                        <input type="number" name="system.attributes.handling.value" value="{{system.attributes.handling.value}}"/>
                    </div>
                    <div class="form-group">
                        <label>Расход, км / топливо</label>
                        <input type="number" name="system.attributes.mpg.value" value="{{system.attributes.mpg.value}}"/>
                    </div>
                </section>

                <section class="z-vehicle-panel">
                    <h3>Походная сводка</h3>
                    <div class="z-vehicle-stat"><span>Запас хода</span><b>{{travelRange}} км</b></div>
                    <div class="z-vehicle-stat"><span>Пассажиры</span><b>{{passengerCount}}</b></div>
                    <div class="z-vehicle-stat {{#if system.broken}}z-vehicle-stat--bad{{/if}}">
                        <span>Состояние</span><b>{{#if system.broken}}Неисправен{{else}}На ходу{{/if}}</b>
                    </div>
                    <div class="z-vehicle-stat {{#if cargoOverloaded}}z-vehicle-stat--bad{{/if}}">
                        <span>Загрузка</span><b>{{currentCargo}} / {{system.cargo.max}}</b>
                    </div>
                    <div class="z-vehicle-stat">
                        <span>Детали в багажнике</span><b>{{repairPartsAvailable}}</b>
                    </div>
                    <button type="button" class="repair-vehicle" {{#unless repairPreview.canRepair}}disabled{{/unless}}>
                        <i class="fas fa-tools"></i> Ремонт
                    </button>
                    {{#if cargoOverloaded}}
                    <p class="z-vehicle-warning">Перегруз: стоит снизить скорость, поднять расход или риск поломки.</p>
                    {{/if}}
                </section>
            </div>
        </div>

        <div class="tab cargo" data-group="primary" data-tab="cargo">
            <section class="z-vehicle-panel">
                <h3>Багажник</h3>
                <div class="form-group">
                    <label>Макс. груз</label>
                    <input type="number" name="system.cargo.max" value="{{system.cargo.max}}"/>
                </div>
                <div class="z-vehicle-loadbar">
                    <div style="width: {{cargoPercent}}%;"></div>
                </div>
            </section>

            <ol class="item-list z-vehicle-list">
                {{#each actor.items as |item|}}
                <li class="item z-vehicle-list-row" data-item-id="{{item.id}}">
                    <img src="{{item.img}}" width="28" height="28"/>
                    <div class="z-vehicle-list-main">
                        <strong>{{item.name}}</strong>
                        <span>Вес: {{item.system.weight}}</span>
                    </div>
                    <b>x{{item.system.quantity}}</b>
                    <div class="item-controls">
                        <a class="item-edit"><i class="fas fa-edit"></i></a>
                        <a class="item-delete"><i class="fas fa-trash"></i></a>
                    </div>
                </li>
                {{/each}}
                {{#unless actor.items}}
                <li class="z-vehicle-empty">Багажник пуст. Перетащи предметы сюда.</li>
                {{/unless}}
            </ol>
        </div>

        <div class="tab passengers" data-group="primary" data-tab="passengers">
            <p class="z-vehicle-note">Перетащи персонажей из списка актёров сюда, чтобы посадить их в транспорт.</p>
            <div class="z-vehicle-passengers">
                {{#each passengers as |p|}}
                <article class="passenger-card z-vehicle-passenger" data-id="{{p.id}}">
                    <img src="{{p.img}}" width="42" height="42"/>
                    <div>
                        <a class="open-passenger" data-id="{{p.id}}">{{p.name}}</a>
                        <span>HP: {{p.system.resources.hp.value}}</span>
                    </div>
                    <a class="remove-passenger" data-id="{{p.id}}" title="Высадить"><i class="fas fa-sign-out-alt"></i></a>
                </article>
                {{/each}}
            </div>
        </div>
    </section>
</form>
